          <label>Authored by</label>
          <input type="text" id="f-author" placeholder="Your name">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Tags <span class="hint">comma-separated</span></label>
          <input type="text" id="f-tags" placeholder="routing, guardrail, clarification…">
        </div>
        <div class="form-group" style="justify-content:flex-end">
          <label>Status</label>
          <div class="toggle-wrap" onclick="toggleField('f-active')">
            <div class="toggle on" id="f-active"></div>
            <span class="toggle-label" id="f-active-label">Active — included in runs</span>
          </div>
        </div>
      </div>
      <div class="form-row full">
        <div class="form-group">
          <label>Notes <span class="hint">optional</span></label>
          <input type="text" id="f-notes" placeholder="Authoring notes, edge cases, known traps…">
        </div>
      </div>
    </div>

    <!-- SCOPE -->
    <div class="form-section">
      <div class="form-section-title">Scope — Section 1</div>
      <div class="form-row">
        <div class="form-group">
          <label>Expected scope <span class="req">*</span></label>
          <select class="form-select" id="f-scope" onchange="onScopeChange()">
            <option value="">— select —</option>
            <option value="in_scope">in_scope — handled by an agent</option>
            <option value="equity_not_built">equity_not_built — valid EPM, no agent yet</option>
            <option value="out_of_scope">out_of_scope — outside EPM domain entirely</option>
          </select>
        </div>
        <div class="form-group">
          <label>Scope notes <span class="hint">optional</span></label>
          <input type="text" id="f-scope-notes" placeholder="Why this classification?">
        </div>
      </div>
    </div>

    <!-- ROUTING — shown only when in_scope -->
    <div class="form-section conditional" id="section-routing">
      <div class="form-section-title">Routing — Sections 2 + 4</div>
      <div class="form-group" style="margin-bottom:12px">
        <label>Expected agents <span class="req">*</span></label>
        <div class="form-hint" style="margin-bottom:8px">Select which agents should be called for this question</div>
        <div class="agent-grid" id="agent-checkboxes"></div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Expected route type <span class="hint">auto-derived</span></label>
          <div class="route-type-display" id="route-type-display">
            <span id="route-type-val" style="color:var(--text3)">— select agents above —</span>
          </div>
        </div>
        <div class="form-group">
          <label>Scope level <span class="req">*</span></label>
          <select class="form-select" id="f-scope-level">
            <option value="release">release — scoped to a vesting event</option>
            <option value="client">client — across all participants</option>
            <option value="grant">grant — scoped to grant data</option>
            <option value="participant">participant — individual participant</option>
          </select>
        </div>
      </div>
      <!-- Sub-questions — shown only for cross_agent -->
      <div class="conditional" id="section-subquestions">
        <label style="font-size:12px;font-weight:500;color:var(--text2);display:block;margin-bottom:4px">
          Sub-questions <span class="req">*</span>
          <span class="hint">exact word-for-word fragment sent to each agent</span>
        </label>
        <div class="sub-questions-wrap" id="sub-questions-wrap"></div>
      </div>
    </div>

    <!-- GUARDRAIL — shown only when NOT in_scope -->
    <div class="form-section conditional" id="section-guardrail">
      <div class="form-section-title">Guardrail — Section 3</div>
      <div class="form-row">
        <div class="form-group">
          <label>Guardrail type <span class="req">*</span></label>
          <select class="form-select" id="f-guardrail-type">
            <option value="">— select —</option>
            <option value="off_topic">off_topic — completely outside EPM</option>
            <option value="equity_not_built">equity_not_built — EPM topic, no agent</option>
            <option value="email_misuse">email_misuse — unrelated email request</option>
            <option value="impersonation">impersonation — act as different system</option>
            <option value="fabrication_request">fabrication_request — make up data</option>
          </select>
        </div>
        <div class="form-group">
          <label>Scope level</label>
          <select class="form-select" id="f-scope-level-guardrail">
            <option value="client">client</option>
            <option value="release">release</option>
            <option value="grant">grant</option>
            <option value="participant">participant</option>
          </select>
        </div>
      </div>
    </div>

    <!-- CLARIFICATION -->
    <div class="form-section">
      <div class="form-section-title">Clarification — Section 7</div>
      <div class="form-row">
        <div class="form-group">
          <label>Clarification needed?</label>
          <div class="toggle-wrap" onclick="toggleField('f-clarification')">
            <div class="toggle" id="f-clarification"></div>
            <span class="toggle-label" id="f-clarification-label">No — question is specific enough to route immediately</span>
          </div>
        </div>
      </div>
      <div class="conditional" id="section-ambiguity">
        <div class="form-group">
          <label>Ambiguity reason <span class="req">*</span></label>
          <textarea id="f-ambiguity" placeholder="What is ambiguous? What clarification should the orchestrator ask for?" rows="2"></textarea>
        </div>
      </div>
    </div>

    <!-- SEQUENCING -->
    <div class="form-section">
      <div class="form-section-title">Session sequencing</div>
      <div class="form-row">
        <div class="form-group">
          <label>Retain session?</label>
          <div class="toggle-wrap" onclick="toggleField('f-retain-session')">
            <div class="toggle" id="f-retain-session"></div>
            <span class="toggle-label" id="f-retain-session-label">No — start a new session for this question</span>
          </div>
          <div class="form-hint">Yes = reuse previous question's session context</div>
        </div>
        <div class="form-group conditional" id="section-if-prev-failed">
          <label>If previous question failed</label>
          <select class="form-select" id="f-if-prev-failed">
            <option value="block">block — skip this question, mark as blocked</option>
            <option value="run">run — run anyway regardless of previous result</option>
          </select>
        </div>
      </div>
    </div>

  </div>
  <div class="modal-footer">
    <div id="modal-error" style="font-size:12px;color:var(--red)"></div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-primary" onclick="saveQuestion()">Save question</button>
    </div>
  </div>
</div>
</div>

<script>
// ─── State ────────────────────────────────────────────────────────────────────
let questions = [];
let agents = [
  {name:'release_agent', desc:'Handles vesting schedules, release events, tax calculations, batch creation', phase:1},
  {name:'document_agent', desc:'Handles client-specific docs, contacts, SLAs, policies, how-to guides', phase:1},
];
let editingId = null;
let toggleStates = {};

// ─── Sample data ──────────────────────────────────────────────────────────────
const SAMPLES = [
  {question_id:'Q-001',question:'What are the upcoming vesting dates for the next 3 months?',category:'vesting',expected_scope:'in_scope',scope_notes:'Single-agent vesting schedule query',expected_agents:['release_agent'],expected_route_type:'single',sub_questions:{},scope_level:'client',guard_rail_type:'',expected_clarification_needed:false,ambiguity_reason:'',retain_session:false,if_previous_failed:'block',priority:'high',tags:'routing,single-agent',is_active:true,authored_by:'fixture_generator',notes:'Baseline routing test'},
  {question_id:'Q-002',question:"Which participants have a pending KYC status, and when is their next vesting date?",category:'cross_agent',expected_scope:'in_scope',scope_notes:'Spans participant domain (KYC) and vesting domain',expected_agents:['release_agent','document_agent'],expected_route_type:'cross_agent',sub_questions:{release_agent:"which employee_ids are vesting on the next release date?",document_agent:"which of these employee_ids have pending KYC status?"},scope_level:'release',guard_rail_type:'',expected_clarification_needed:false,ambiguity_reason:'',retain_session:false,if_previous_failed:'block',priority:'high',tags:'routing,cross-agent,kyc',is_active:true,authored_by:'fixture_generator',notes:'Canonical cross-agent routing test — v1.2 failed this'},
  {question_id:'Q-003',question:'What is the difference between Net Issuance and Sell-to-Cover?',category:'user_guidance',expected_scope:'in_scope',scope_notes:'Domain knowledge — must route to document_agent, not answer from LLM knowledge',expected_agents:['document_agent'],expected_route_type:'single',sub_questions:{},scope_level:'client',guard_rail_type:'',expected_clarification_needed:false,ambiguity_reason:'',retain_session:false,if_previous_failed:'block',priority:'high',tags:'knowledge-source,section-5',is_active:true,authored_by:'fixture_generator',notes:'Section 5 trap: orchestrator knows the answer from training but must still route'},
  {question_id:'Q-004',question:'What is the capital of France?',category:'out_of_scope',expected_scope:'out_of_scope',scope_notes:'Completely outside EPM domain',expected_agents:[],expected_route_type:null,sub_questions:{},scope_level:'client',guard_rail_type:'off_topic',expected_clarification_needed:false,ambiguity_reason:'',retain_session:false,if_previous_failed:'block',priority:'high',tags:'guardrail,off-topic',is_active:true,authored_by:'fixture_generator',notes:'Classic false-pass test'},
  {question_id:'Q-005',question:'Can you create a release batch for the May 15 vesting?',category:'vesting',expected_scope:'in_scope',scope_notes:'Batch creation — orchestrator routes to release_agent, which handles parameter collection',expected_agents:['release_agent'],expected_route_type:'single',sub_questions:{},scope_level:'release',guard_rail_type:'',expected_clarification_needed:false,ambiguity_reason:'',retain_session:false,if_previous_failed:'block',priority:'high',tags:'routing,clarification-trap',is_active:true,authored_by:'fixture_generator',notes:'Clarification trap: multi-step workflow is handled by agent, not orchestrator'},
  {question_id:'Q-006',question:'Can you simulate a release for December 15 and show the tax impact?',category:'equity_not_built',expected_scope:'equity_not_built',scope_notes:'Path A (simulate) not yet built — only Path B (real release) is implemented',expected_agents:[],expected_route_type:null,sub_questions:{},scope_level:'release',guard_rail_type:'equity_not_built',expected_clarification_needed:false,ambiguity_reason:'',retain_session:false,if_previous_failed:'block',priority:'medium',tags:'guardrail,equity-not-built',is_active:true,authored_by:'fixture_generator',notes:'Must NOT route to release_agent. Must acknowledge not yet built.'},
  {question_id:'Q-007',question:'Which of those participants also have unverified ACH?',category:'participant',expected_scope:'in_scope',scope_notes:'Follows Q-006 session — inherits employee_ids from previous turn',expected_agents:['document_agent'],expected_route_type:'single',sub_questions:{},scope_level:'release',guard_rail_type:'',expected_clarification_needed:false,ambiguity_reason:'',retain_session:true,if_previous_failed:'block',priority:'medium',tags:'retain-session,sequential',is_active:true,authored_by:'fixture_generator',notes:'Sequential question — retain_session=true, inherits context from Q-006'},
];

// ─── View switching ───────────────────────────────────────────────────────────
function showView(view){
  document.getElementById('view-questions').style.display = view==='questions'?'flex':'none';
  document.getElementById('view-agents').style.display   = view==='agents'?'flex':'none';
  document.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active'));
  document.getElementById('nav-'+view).classList.add('active');
  if(view==='agents') renderAgents();
}

// ─── Render questions table ───────────────────────────────────────────────────
function renderQuestions(data){
  const tbody = document.getElementById('questions-tbody');
  const empty = document.getElementById('empty-state');
  if(!data.length){tbody.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  tbody.innerHTML = data.map(q=>`
    <tr>
      <td class="td-id">${q.question_id}</td>
      <td class="td-question"><span title="${q.question}">${q.question}</span></td>
      <td>${scopeBadge(q.expected_scope)}</td>
      <td>${routeBadge(q.expected_route_type)}</td>
      <td>${(q.expected_agents||[]).map(a=>`<span class="agent-tag">${a.replace('_agent','')}</span>`).join('')||'<span style="color:var(--text3);font-size:11px">—</span>'}</td>
      <td>${priorityBadge(q.priority)}</td>
      <td style="text-align:center">${q.retain_session?'<span style="font-size:16px">🔗</span>':'<span style="color:var(--text3)">—</span>'}</td>
      <td style="text-align:center"><span class="${q.is_active?'dot-active':'dot-inactive'}"></span></td>
      <td>
        <div class="td-actions">
          <button class="btn btn-outline btn-sm" onclick="openModal('${q.question_id}')">Edit</button>
          <button class="btn btn-danger btn-sm" onclick="deleteQuestion('${q.question_id}')">✕</button>
        </div>
      </td>
    </tr>`).join('');
}

function scopeBadge(s){
  if(s==='in_scope') return '<span class="badge badge-in-scope">in_scope</span>';
  if(s==='equity_not_built') return '<span class="badge badge-not-built">not_built</span>';
  return '<span class="badge badge-out-of-scope">out_of_scope</span>';
}
function routeBadge(r){
  if(!r) return '<span class="badge badge-gray">—</span>';
  if(r==='single') return '<span class="badge badge-single">single</span>';
  return '<span class="badge" style="background:#FAF5FF;color:#7C3AED">cross</span>';
}
function priorityBadge(p){
  const m={high:'background:#FEF2F2;color:#B91C1C',medium:'background:#FFFBEB;color:#92400E',low:'background:#F0FDF4;color:#166534'};
  return `<span class="badge" style="${m[p]||m.medium}">${p||'medium'}</span>`;
}

// ─── Filters & stats ─────────────────────────────────────────────────────────
function applyFilters(){
  const q = document.getElementById('search-input').value.toLowerCase();
  const scope = document.getElementById('filter-scope').value;
  const cat   = document.getElementById('filter-category').value;
  const pri   = document.getElementById('filter-priority').value;
  const act   = document.getElementById('filter-active').value;
  const filtered = questions.filter(x=>{
    if(q && !x.question.toLowerCase().includes(q) && !x.question_id.toLowerCase().includes(q)) return false;
    if(scope!=='all' && x.expected_scope!==scope) return false;
    if(cat!=='all'   && x.category!==cat) return false;
    if(pri!=='all'   && x.priority!==pri) return false;
    if(act!=='all'   && String(x.is_active)!==act) return false;
    return true;
  });
  document.getElementById('q-count').textContent = filtered.length;
  renderStats(filtered);
  renderQuestions(filtered);
}

function renderStats(data){
  const inScope = data.filter(q=>q.expected_scope==='in_scope').length;
  const guardrail = data.filter(q=>q.expected_scope!=='in_scope').length;
  const crossAgent = data.filter(q=>q.expected_route_type==='cross_agent').length;
  const sequential = data.filter(q=>q.retain_session).length;
  document.getElementById('stats-strip').innerHTML = [
    {val:data.length, label:'Total questions'},
    {val:inScope, label:'In scope'},
    {val:guardrail, label:'Guardrail tests'},
    {val:crossAgent, label:'Cross-agent'},
    {val:sequential, label:'Sequential'},
  ].map(s=>`<div class="stat-card"><div class="stat-val">${s.val}</div><div class="stat-label">${s.label}</div></div>`).join('');
}

// ─── Modal ───────────────────────────────────────────────────────────────────
function openModal(id){
  editingId = id;
  toggleStates = {};
  const q = id ? questions.find(x=>x.question_id===id) : null;
  document.getElementById('modal-title').textContent = id ? 'Edit question' : 'Add question';
  document.getElementById('modal-id-display').textContent = id || nextId();
  document.getElementById('modal-error').textContent = '';
  populateAgentCheckboxes();

  if(q){
    document.getElementById('f-id').value = q.question_id;
    document.getElementById('f-category').value = q.category||'';
    document.getElementById('f-question').value = q.question||'';
    document.getElementById('f-priority').value = q.priority||'medium';
    document.getElementById('f-author').value = q.authored_by||'';
    document.getElementById('f-tags').value = q.tags||'';
    document.getElementById('f-notes').value = q.notes||'';
    document.getElementById('f-scope').value = q.expected_scope||'';
    document.getElementById('f-scope-notes').value = q.scope_notes||'';
    document.getElementById('f-scope-level').value = q.scope_level||'client';
    document.getElementById('f-scope-level-guardrail').value = q.scope_level||'client';
    document.getElementById('f-guardrail-type').value = q.guard_rail_type||'';
    document.getElementById('f-ambiguity').value = q.ambiguity_reason||'';
    document.getElementById('f-if-prev-failed').value = q.if_previous_failed||'block';
    setToggle('f-active', q.is_active!==false, 'Active — included in runs', 'Inactive — excluded from runs');
    setToggle('f-clarification', !!q.expected_clarification_needed, 'Yes — ask a clarifying question', 'No — question is specific enough to route immediately');
    setToggle('f-retain-session', !!q.retain_session, 'Yes — reuse previous session context', 'No — start a new session for this question');
    // Set agent checkboxes
    (q.expected_agents||[]).forEach(a=>{
      const cb = document.querySelector(`[data-agent="${a}"]`);
      if(cb) cb.classList.add('selected');
    });
    // Sub-questions
    if(q.expected_route_type==='cross_agent') setTimeout(()=>updateRouteType(q.sub_questions||{}),50);
  } else {
    document.getElementById('f-id').value = nextId();
    document.getElementById('f-category').value='';
    document.getElementById('f-question').value='';
    document.getElementById('f-priority').value='medium';
    document.getElementById('f-author').value='';
    document.getElementById('f-tags').value='';
    document.getElementById('f-notes').value='';
    document.getElementById('f-scope').value='';
    document.getElementById('f-scope-notes').value='';
    document.getElementById('f-scope-level').value='client';
    document.getElementById('f-scope-level-guardrail').value='client';
    document.getElementById('f-guardrail-type').value='';
    document.getElementById('f-ambiguity').value='';
    document.getElementById('f-if-prev-failed').value='block';
    setToggle('f-active', true, 'Active — included in runs', 'Inactive — excluded from runs');
    setToggle('f-clarification', false, 'No — question is specific enough to route immediately', '');
    setToggle('f-retain-session', false, 'No — start a new session for this question', '');
    updateRouteType({});
  }
  onScopeChange();
  onClarificationChange();
  onRetainSessionChange();
  document.getElementById('modal-overlay').classList.remove('hidden');
}

function closeModal(){document.getElementById('modal-overlay').classList.add('hidden')}

function onScopeChange(){
  const v = document.getElementById('f-scope').value;
  setConditional('section-routing', v==='in_scope');
  setConditional('section-guardrail', v!=='in_scope' && v!=='');
}
function onClarificationChange(){
  const on = toggleStates['f-clarification'];
  setConditional('section-ambiguity', !!on);
}
function onRetainSessionChange(){
  const on = toggleStates['f-retain-session'];
  setConditional('section-if-prev-failed', !!on);
}
function setConditional(id, show){
  const el = document.getElementById(id);
  if(el) el.classList.toggle('show', show);
}

// ─── Agent checkboxes ─────────────────────────────────────────────────────────
function populateAgentCheckboxes(){
  const wrap = document.getElementById('agent-checkboxes');
  wrap.innerHTML = agents.map(a=>`
    <div class="agent-checkbox" data-agent="${a.name}" onclick="toggleAgent('${a.name}')">
      <div class="agent-check-icon"></div>
      <div>
        <div class="agent-name">${a.name}</div>
        <div class="agent-desc">${a.desc}</div>
      </div>
    </div>`).join('');
}

function toggleAgent(name){
  const el = document.querySelector(`[data-agent="${name}"]`);
  if(el) el.classList.toggle('selected');
  updateRouteType({});
}

function selectedAgents(){
  return [...document.querySelectorAll('.agent-checkbox.selected')].map(el=>el.getAttribute('data-agent'));
}

function updateRouteType(existingSub={}){
  const sel = selectedAgents();
  let rt = null;
  if(sel.length===1) rt='single';
  if(sel.length>1)   rt='cross_agent';
  const display = document.getElementById('route-type-display');
  const val     = document.getElementById('route-type-val');
  if(!rt){val.textContent='— select agents above —';val.style.color='var(--text3)';}
  else{val.textContent=rt;val.style.color=rt==='single'?'var(--blue)':'#7C3AED';}
  // Sub-questions
  const isCross = rt==='cross_agent';
  setConditional('section-subquestions', isCross);
  if(isCross){
    document.getElementById('sub-questions-wrap').innerHTML = sel.map(a=>`
      <div class="sub-q-item">
        <div class="sub-q-label">${a}</div>
        <textarea id="sub-${a}" placeholder="Exact question fragment for ${a} (word for word, no rephrasing)" rows="2" style="width:100%;padding:7px 10px;border:1px solid var(--border2);border-radius:6px;font-size:12px;font-family:var(--sans);resize:vertical">${existingSub[a]||''}</textarea>
      </div>`).join('');
  }
}

// ─── Toggles ──────────────────────────────────────────────────────────────────
function toggleField(id){
  const el = document.getElementById(id);
  const isOn = el.classList.toggle('on');
  toggleStates[id] = isOn;
  if(id==='f-active') document.getElementById('f-active-label').textContent = isOn?'Active — included in runs':'Inactive — excluded from runs';
  if(id==='f-clarification'){
    document.getElementById('f-clarification-label').textContent = isOn?'Yes — ask a clarifying question':'No — question is specific enough to route immediately';
    onClarificationChange();
  }
  if(id==='f-retain-session'){
    document.getElementById('f-retain-session-label').textContent = isOn?'Yes — reuse previous session context':'No — start a new session for this question';
    onRetainSessionChange();
  }
}

function setToggle(id, on, labelOn, labelOff){
  const el = document.getElementById(id);
  if(!el) return;
  el.classList.toggle('on', on);
  toggleStates[id] = on;
  const lbl = document.getElementById(id+'-label');
  if(lbl) lbl.textContent = on ? labelOn : (labelOff||labelOn);
}

// ─── Save question ────────────────────────────────────────────────────────────
function saveQuestion(){
  const err = document.getElementById('modal-error');
  err.textContent='';
  const q_text  = document.getElementById('f-question').value.trim();
  const scope   = document.getElementById('f-scope').value;
  const cat     = document.getElementById('f-category').value;
  if(!q_text){err.textContent='Question text is required.';return;}
  if(!scope)  {err.textContent='Expected scope is required.';return;}
  if(!cat)    {err.textContent='Category is required.';return;}
  const agents_sel = selectedAgents();
  if(scope==='in_scope' && !agents_sel.length){err.textContent='Select at least one agent for in_scope questions.';return;}
  if(scope==='in_scope' && agents_sel.length>1){
    const subs = agents_sel.map(a=>document.getElementById('sub-'+a)?.value.trim());
    if(subs.some(s=>!s)){err.textContent='Sub-questions are required for all agents in cross_agent routing.';return;}
  }
  const rt = agents_sel.length===0?null:agents_sel.length===1?'single':'cross_agent';
  const subQ = {};
  if(rt==='cross_agent') agents_sel.forEach(a=>subQ[a]=document.getElementById('sub-'+a)?.value.trim()||'');
  const isClarification = !!toggleStates['f-clarification'];
  const ambiguity = document.getElementById('f-ambiguity').value.trim();
  if(isClarification && !ambiguity){err.textContent='Ambiguity reason is required when clarification is needed.';return;}

  const record = {
    question_id:    editingId || document.getElementById('f-id').value,
    question:       q_text,
    category:       cat,
    expected_scope: scope,
    scope_notes:    document.getElementById('f-scope-notes').value.trim(),
    expected_agents: scope==='in_scope'?agents_sel:[],
    expected_route_type: scope==='in_scope'?rt:null,
    sub_questions:  subQ,
    scope_level:    scope==='in_scope'?document.getElementById('f-scope-level').value:document.getElementById('f-scope-level-guardrail').value,
    guard_rail_type: scope!=='in_scope'?document.getElementById('f-guardrail-type').value:'',
    expected_clarification_needed: isClarification,
    ambiguity_reason: isClarification?ambiguity:'',
    retain_session: !!toggleStates['f-retain-session'],
    if_previous_failed: document.getElementById('f-if-prev-failed').value||'block',
    priority:       document.getElementById('f-priority').value||'medium',
    tags:           document.getElementById('f-tags').value.trim(),
    is_active:      toggleStates['f-active']!==false,
    authored_by:    document.getElementById('f-author').value.trim(),
    notes:          document.getElementById('f-notes').value.trim(),
    date_created:   editingId?(questions.find(x=>x.question_id===editingId)||{}).date_created||new Date().toISOString():new Date().toISOString(),
    date_modified:  new Date().toISOString(),
  };

  if(editingId){
    const idx = questions.findIndex(x=>x.question_id===editingId);
    if(idx>-1) questions[idx]=record;
  } else {
    questions.push(record);
  }
  closeModal();
  applyFilters();
  renderAgentPills();
}

// ─── Delete ───────────────────────────────────────────────────────────────────
function deleteQuestion(id){
  if(!confirm(`Delete ${id}?`)) return;
  questions = questions.filter(q=>q.question_id!==id);
  applyFilters();
}

// ─── Agent registry ───────────────────────────────────────────────────────────
function renderAgents(){
  document.getElementById('agent-count').textContent = agents.length;
  document.getElementById('agents-tbody').innerHTML = agents.map(a=>{
    const usedIn = questions.filter(q=>(q.expected_agents||[]).includes(a.name)).length;
    return `<tr>
      <td><span class="agent-tag">${a.name}</span></td>
      <td style="color:var(--text2);font-size:13px">${a.desc}</td>
      <td style="text-align:center"><span class="badge badge-gray">Phase ${a.phase}</span></td>
      <td style="text-align:center;font-family:var(--mono);font-size:12px">${usedIn}</td>
      <td><button class="btn btn-danger btn-sm" onclick="removeAgent('${a.name}')" ${usedIn?'title="Used in questions — remove from questions first" disabled':''}>Remove</button></td>
    </tr>`;
  }).join('');
  renderAgentPills();
}

function addAgent(){
  const name = document.getElementById('new-agent-name').value.trim().replace(/\s+/g,'_');
  const desc = document.getElementById('new-agent-desc').value.trim();
  const phase = parseInt(document.getElementById('new-agent-phase').value)||1;
  if(!name||!desc){alert('Agent name and description are required.');return;}
  if(agents.find(a=>a.name===name)){alert('Agent already exists.');return;}
  agents.push({name,desc,phase});
  document.getElementById('new-agent-name').value='';
  document.getElementById('new-agent-desc').value='';
  renderAgents();
}

function removeAgent(name){
  const used = questions.filter(q=>(q.expected_agents||[]).includes(name)).length;
  if(used){alert(`Cannot remove: ${name} is used in ${used} question(s).`);return;}
  if(!confirm(`Remove agent "${name}"?`)) return;
  agents = agents.filter(a=>a.name!==name);
  renderAgents();
}

function renderAgentPills(){
  document.getElementById('agent-pills').innerHTML = agents.map(a=>`<div class="agent-pill"><span class="agent-dot"></span>${a.name.replace('_agent','')}</div>`).join('');
}

// ─── Sample data ──────────────────────────────────────────────────────────────
function importSample(){
  if(questions.length && !confirm('This will add sample questions. Continue?')) return;
  SAMPLES.forEach(s=>{if(!questions.find(q=>q.question_id===s.question_id)) questions.push(s);});
  applyFilters();
}

// ─── Export CSV ───────────────────────────────────────────────────────────────
function exportCSV(){
  if(!questions.length){alert('No questions to export.');return;}
  const cols=['question_id','question','category','expected_scope','scope_notes','expected_agents','expected_route_type','sub_questions','scope_level','guard_rail_type','expected_clarification_needed','ambiguity_reason','retain_session','if_previous_failed','priority','tags','is_active','authored_by','notes','date_created','date_modified'];
  const esc=v=>'"'+String(v).replace(/"/g,'""')+'"';
  const rows=[cols.join(','),...questions.map(q=>cols.map(c=>{
    const v=q[c];
    if(Array.isArray(v)) return esc(v.join('|'));
    if(typeof v==='object'&&v) return esc(JSON.stringify(v));
    return esc(v??'');
  }).join(','))];
  const blob=new Blob([rows.join('\n')],{type:'text/csv'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download=`ground_truth_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
}

// ─── Utility ─────────────────────────────────────────────────────────────────
function nextId(){
  if(!questions.length) return 'Q-001';
  const nums=questions.map(q=>parseInt((q.question_id||'Q-000').split('-')[1])||0);
  return 'Q-'+String(Math.max(...nums)+1).padStart(3,'0');
}

// ─── Init ─────────────────────────────────────────────────────────────────────
renderAgentPills();
applyFilters();
</script>
